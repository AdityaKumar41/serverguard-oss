# ServerGuard — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit this file with real values.
#
# Load with: set -a; source .env; set +a
# Or use your preferred .env loader.

# ── AI Model Providers ────────────────────────────────────────────────────────
# Set one of these based on your chosen provider (sg setup or sg model)

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (access 200+ models with one key)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# OpenCode (open-source AI coding agent)
# Get key at: https://opencode.ai
OPENCODE_API_KEY=oc-...

# Groq (ultra-fast inference, generous free tier)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Mistral AI
# Get key at: https://console.mistral.ai
MISTRAL_API_KEY=...

# Together AI (open-source models)
# Get key at: https://api.together.xyz
TOGETHER_API_KEY=...

# Ollama: no key needed — just make sure `ollama serve` is running

# ── Notification Channels ─────────────────────────────────────────────────────

# Telegram
# 1. Create bot: @BotFather → /newbot → copy token
# 2. Get chat ID: send a message, then GET https://api.telegram.org/bot<TOKEN>/getUpdates
SERVERGUARD_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
SERVERGUARD_TELEGRAM_CHAT_ID=-100123456789

# Discord
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
SERVERGUARD_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Slack
# api.slack.com/apps → Incoming Webhooks → Add to Workspace → Copy URL
SERVERGUARD_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Custom Webhook (HMAC-signed)
SERVERGUARD_WEBHOOK_URL=https://your-service.example.com/hook
SERVERGUARD_WEBHOOK_SECRET=your-signing-secret   # optional, used for HMAC

# Email (SMTP)
# For Gmail: use an App Password, not your account password
# https://support.google.com/accounts/answer/185833
SERVERGUARD_SMTP_HOST=smtp.gmail.com
SERVERGUARD_SMTP_PORT=587
SERVERGUARD_SMTP_USER=alerts@example.com
SERVERGUARD_SMTP_PASSWORD=your-app-password
SERVERGUARD_SMTP_TO=ops@example.com
