# ServerGuard environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Notification channels (optional) ─────────────────────────────────────────
# Slack webhook URL for alert delivery
# SERVERGUARD_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Telegram bot token and chat ID
# SERVERGUARD_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# SERVERGUARD_TELEGRAM_CHAT_ID=-100123456789

# SMTP credentials for email alerts
# SERVERGUARD_SMTP_HOST=smtp.gmail.com
# SERVERGUARD_SMTP_PORT=587
# SERVERGUARD_SMTP_USER=alerts@example.com
# SERVERGUARD_SMTP_PASSWORD=your-app-password
# SERVERGUARD_SMTP_TO=ops@example.com

# Generic webhook URL
# SERVERGUARD_WEBHOOK_URL=https://your-service.example.com/webhook

# ── AI / anomaly detection (optional) ────────────────────────────────────────
# Path to a custom ONNX model for anomaly scoring (leave blank to use built-in)
# SERVERGUARD_ONNX_MODEL_PATH=

# ── Advanced daemon settings ─────────────────────────────────────────────────
# Override the default log level (DEBUG, INFO, WARNING, ERROR)
# SERVERGUARD_LOG_LEVEL=INFO

# Maximum log lines per second per source (default: 10000)
# SERVERGUARD_MAX_LINES_PER_SECOND=10000
